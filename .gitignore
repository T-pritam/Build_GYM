# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native - build artifacts only (android/ and ios/ are committed for prebuild)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Android build artifacts
android/app/build/
android/build/
android/app/.cxx/
android/.gradle/
android/local.properties

# iOS build artifacts
ios/build/
ios/Pods/
ios/*.xcworkspace/xcuserdata
ios/*.xcodeproj/xcuserdata
ios/*.xcodeproj/project.xcworkspace/xcuserdata

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo